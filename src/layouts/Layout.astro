---
import '../styles/global.css';
import { negocio, locales } from '@data/business';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = `${negocio.nombre} · Tacos al pastor auténticos en Madrid`,
  description = negocio.descripcion,
  image = 'https://images.unsplash.com/photo-1565299507177-b0ac66763828?w=1200&q=80',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();

// JSON-LD Restaurant Schema — mapea datos reales del negocio
const localPrincipal = locales.find((l) => l.destacado) ?? locales[0];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Restaurant',
  name: negocio.nombre,
  description: negocio.descripcion,
  url: canonical,
  telephone: negocio.telefono,
  email: negocio.email,
  image: [image],
  priceRange: '€',
  servesCuisine: ['Mexican', 'Tacos', 'Street Food'],
  acceptsReservations: 'False',
  address: {
    '@type': 'PostalAddress',
    streetAddress: localPrincipal.direccion,
    addressLocality: localPrincipal.ciudad,
    postalCode: localPrincipal.cp,
    addressCountry: 'ES',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: localPrincipal.lat,
    longitude: localPrincipal.lng,
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
      opens: '13:00',
      closes: '24:00',
    },
  ],
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: negocio.rating,
    reviewCount: negocio.resenasTotales,
    bestRating: 5,
    worstRating: 1,
  },
  sameAs: [negocio.redes.instagram, negocio.redes.facebook, negocio.redes.tripadvisor],
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#E87A2C" />
    <meta name="author" content={negocio.nombre} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content="restaurant.restaurant" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content={negocio.nombre} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Geo -->
    <meta name="geo.region" content="ES-MD" />
    <meta name="geo.placename" content="Madrid" />
    <meta
      name="geo.position"
      content={`${localPrincipal.lat};${localPrincipal.lng}`}
    />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Caveat:wght@500;700&family=Fraunces:ital,opsz,wght@0,9..144,400..900;1,9..144,400..900&family=Space+Mono:wght@400;700&display=swap"
    />

    <!-- Leaflet CSS -->
    <link
      rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
      crossorigin=""
    />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- SVG filters reutilizables -->
    <slot name="head" />
  </head>
  <body class="min-h-screen font-body">
    <!-- SVG filter para tipografía líquida -->
    <svg width="0" height="0" style="position:absolute" aria-hidden="true">
      <defs>
        <filter id="liquid-distort">
          <feTurbulence
            type="fractalNoise"
            baseFrequency="0.012 0.018"
            numOctaves="2"
            seed="3"
          >
            <animate
              attributeName="baseFrequency"
              dur="14s"
              values="0.012 0.018; 0.018 0.012; 0.012 0.018"
              repeatCount="indefinite"
            />
          </feTurbulence>
          <feDisplacementMap in="SourceGraphic" scale="8" />
        </filter>
      </defs>
    </svg>

    <slot />

    <script>
      // Theming dinámico de fondo según sección visible (Intersection Observer)
      const sections = document.querySelectorAll<HTMLElement>('[data-bg]');
      if ('IntersectionObserver' in window && sections.length) {
        const root = document.documentElement;
        const obs = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting && e.intersectionRatio > 0.4) {
                const bg = e.target.getAttribute('data-bg');
                const fg = e.target.getAttribute('data-fg');
                if (bg) root.style.setProperty('--bg-now', bg);
                if (fg) root.style.setProperty('--fg-now', fg);
              }
            });
          },
          { threshold: [0.4, 0.6] }
        );
        sections.forEach((s) => obs.observe(s));
      }

      // Cursor magnético en elementos con [data-magnetic]
      const magnetics = document.querySelectorAll<HTMLElement>('[data-magnetic]');
      magnetics.forEach((el) => {
        el.addEventListener('mousemove', (ev) => {
          const e = ev as MouseEvent;
          const rect = el.getBoundingClientRect();
          const x = e.clientX - rect.left - rect.width / 2;
          const y = e.clientY - rect.top - rect.height / 2;
          el.style.transform = `translate(${x * 0.18}px, ${y * 0.18}px)`;
        });
        el.addEventListener('mouseleave', () => {
          el.style.transform = 'translate(0,0)';
        });
      });

      // Bento spotlight — mouse position en cards
      const cards = document.querySelectorAll<HTMLElement>('.bento-card');
      cards.forEach((c) => {
        c.addEventListener('mousemove', (ev) => {
          const e = ev as MouseEvent;
          const r = c.getBoundingClientRect();
          c.style.setProperty('--mx', `${e.clientX - r.left}px`);
          c.style.setProperty('--my', `${e.clientY - r.top}px`);
        });
      });
    </script>
  </body>
</html>
