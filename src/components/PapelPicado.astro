---
// Banner de papel picado SVG — guirnalda mexicana tradicional con animación sutil
// Props:
//   tint: color (override). Default: rotación cíclica.
//   count: número de banderines (default 8)
interface Props {
  tint?: string;
  count?: number;
  class?: string;
}
const { tint, count = 8, class: extra = '' } = Astro.props;

const colores = ['#DC2626', '#2D9B6B', '#F2D785', '#E87A2C', '#4FC3F7', '#F2D785'];
---

<div class={`papel-picado relative w-full pointer-events-none ${extra}`} aria-hidden="true">
  <svg viewBox={`0 0 ${count * 80} 100`} preserveAspectRatio="none" class="w-full h-20 sm:h-24 block">
    <line x1="0" y1="6" x2={count * 80} y2="6" stroke="#0B0908" stroke-width="1.2" opacity="0.6"/>
    {Array.from({ length: count }).map((_, i) => {
      const x = i * 80;
      const c = tint ?? colores[i % colores.length];
      const sway = (i % 2 === 0 ? 0 : 1.6);
      return (
        <g style={`transform-origin:${x + 40}px 6px; animation: pp-sway 5.6s ease-in-out infinite; animation-delay:${i * 0.18}s`}>
          {/* Banderín principal */}
          <path d={`M${x + 6} 6 L${x + 6} 70 Q${x + 40} 92 ${x + 74} 70 L${x + 74} 6 Z`} fill={c}/>

          {/* Recortes decorativos — corazón central */}
          <circle cx={x + 40} cy={28} r="6" fill="#FAF6EC"/>
          <path d={`M${x + 36} 42 Q${x + 40} 36 ${x + 44} 42 Q${x + 48} 50 ${x + 40} 56 Q${x + 32} 50 ${x + 36} 42 Z`} fill="#FAF6EC"/>

          {/* Puntos decorativos */}
          <circle cx={x + 22} cy={20} r="2" fill="#FAF6EC"/>
          <circle cx={x + 58} cy={20} r="2" fill="#FAF6EC"/>
          <circle cx={x + 22} cy={52} r="2" fill="#FAF6EC"/>
          <circle cx={x + 58} cy={52} r="2" fill="#FAF6EC"/>

          {/* Borde dentado superior */}
          <path d={`M${x + 6} 6 L${x + 10} 14 L${x + 18} 6 L${x + 26} 14 L${x + 34} 6 L${x + 42} 14 L${x + 50} 6 L${x + 58} 14 L${x + 66} 6 L${x + 74} 6`} fill={c}/>
        </g>
      );
    })}
  </svg>
</div>

<style>
  @keyframes pp-sway {
    0%, 100% { transform: rotate(-2deg); }
    50% { transform: rotate(2deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .papel-picado g { animation: none !important; }
  }
</style>
