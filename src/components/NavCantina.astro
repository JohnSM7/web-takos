---
import { negocio } from '@data/business';
---

<nav
  class="fixed top-0 left-0 right-0 z-50 px-4 sm:px-8 py-3 flex items-center justify-between"
>
  <a href="#top" class="flex items-center gap-3 group">
    <span class="block w-12 h-12 rounded-full overflow-hidden bg-achiote shadow-lg transition-transform group-hover:rotate-[8deg]">
      <img src={negocio.logo} alt={`Logo ${negocio.nombre}`} class="w-full h-full object-cover" width="48" height="48"/>
    </span>
    <span class="hidden sm:block font-display text-lg tracking-tight text-noche">
      Takos al Pastor
    </span>
  </a>

  <ul class="hidden md:flex items-center gap-0.5 bg-crema/90 backdrop-blur-md px-2 py-1.5 rounded-full shadow-md">
    {[
      { href: '#carta', label: 'Carta' },
      { href: '#experiencia', label: 'Experiencia' },
      { href: '#resenas', label: 'Reseñas' },
      { href: '#donde', label: 'Dónde' },
    ].map((i) => (
      <li>
        <a
          href={i.href}
          class="block px-4 py-1.5 rounded-full font-mono text-[10px] tracking-[0.18em] text-noche hover:bg-chile hover:text-crema transition uppercase font-bold"
        >
          {i.label}
        </a>
      </li>
    ))}
  </ul>

  <a href="#donde" data-magnetic class="btn-pop btn-pop--jade !py-2.5 !px-4 !text-[10px]">
    Cómo llegar
  </a>
</nav>
