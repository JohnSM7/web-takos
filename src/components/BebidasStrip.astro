---
import { biblioteca } from '@data/business';
import Stickers from './Stickers.astro';

const jarritosSabores = ['Tamarindo', 'Mandarina', 'Jamaica', 'Mango', 'Lima', 'Fresa', 'Sandía', 'Piña'];
const cervezasSabores = ['Corona Extra', 'Modelo Especial', 'Pacífico Clara', 'Victoria', 'XX Lager'];
---

<Stickers />

<section
  data-bg="#4FC3F7"
  data-fg="#0B0908"
  class="relative w-full py-24 sm:py-32 px-5 sm:px-10 lg:px-12 overflow-hidden"
>
  <!-- Patrón talavera de fondo (azulejo) -->
  <div
    aria-hidden="true"
    class="absolute inset-0 opacity-[0.18] pointer-events-none"
    style="background-image:url('data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2280%22 height=%2280%22 viewBox=%220 0 80 80%22%3E%3Cg fill=%22none%22 stroke=%22%230B0908%22 stroke-width=%221.6%22%3E%3Crect x=%2210%22 y=%2210%22 width=%2260%22 height=%2260%22 transform=%22rotate(45 40 40)%22/%3E%3Ccircle cx=%2240%22 cy=%2240%22 r=%2210%22/%3E%3Cpath d=%22M40 16 L40 64 M16 40 L64 40%22/%3E%3C/g%3E%3C/svg%3E'); background-size: 64px 64px;"
  ></div>

  <div class="relative z-10 max-w-6xl mx-auto">

    <!-- Encabezado -->
    <header class="mb-14 sm:mb-16 text-center">
      <span class="sello text-noche mb-6 inline-block">★ Para beber ★</span>
      <h2 class="leading-[0.92] tracking-tight">
        <span class="block font-display text-noche text-5xl sm:text-7xl uppercase">
          Frescura
        </span>
        <span class="block serif-italic text-chile text-5xl sm:text-7xl">
          mexicana de verdad
        </span>
      </h2>
      <p class="mt-6 max-w-xl mx-auto serif-body text-noche text-base sm:text-lg">
        Jarritos de cristal, micheladas con tajín y cerveza fría como manda la cantina.
        Importados de México, a precio honesto.
      </p>
    </header>

    <!-- BLOQUE 1: Jarritos con foto real -->
    <article class="relative bg-crema rounded-3xl overflow-hidden shadow-2xl mb-6 grid md:grid-cols-5 gap-0">
      <!-- Foto Jarritos grupo -->
      <div class="md:col-span-3 relative aspect-[4/3] md:aspect-auto overflow-hidden">
        <img src="/images/bebidas/jarritos-grupo.jpg" alt="Botellas de Jarritos: Mango, Mineragua, Jamaica, Mexican Cola, Fruit Punch" class="w-full h-full object-cover" loading="lazy"/>
        <!-- Sticker lima decorativo -->
        <svg class="absolute top-4 right-4 w-14 h-14 -rotate-6 drop-shadow-lg">
          <use href="#sticker-lima"/>
        </svg>
      </div>

      <!-- Contenido -->
      <div class="md:col-span-2 p-6 sm:p-8 flex flex-col justify-between">
        <div>
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-display text-3xl sm:text-4xl text-noche uppercase tracking-tight">Jarritos</h3>
            <span class="font-display text-2xl text-crema bg-chile px-3 py-1 rounded-full">2 €</span>
          </div>
          <p class="serif-body text-noche/80 text-base leading-snug mb-5">
            El refresco mexicano por excelencia. Botella de cristal,
            sabor frutal real, espuma generosa. Importados directamente.
          </p>
          <div class="flex flex-wrap gap-1.5">
            {jarritosSabores.map((s) => (
              <span class="px-2.5 py-1 text-[10px] font-mono uppercase tracking-widest bg-jade text-crema rounded-full">
                {s}
              </span>
            ))}
          </div>
        </div>
        <p class="mt-5 font-hand text-2xl text-chile">¡Que buenos son!</p>
      </div>
    </article>

    <!-- BLOQUE 2: Michelada (hero card con foto del local) -->
    <article class="relative rounded-3xl overflow-hidden shadow-2xl mb-6 grid md:grid-cols-5 gap-0 bg-noche">
      <!-- Foto interior barra del local -->
      <div class="md:col-span-2 relative aspect-[4/3] md:aspect-auto overflow-hidden order-2 md:order-1">
        <img src={biblioteca.interior.barra} alt="Barra del local Takos al Pastor" class="w-full h-full object-cover" loading="lazy"/>
        <div class="absolute inset-0 bg-gradient-to-r md:from-noche md:via-noche/30 to-transparent"></div>
      </div>

      <!-- Contenido michelada -->
      <div class="md:col-span-3 p-6 sm:p-10 relative order-1 md:order-2 text-crema">
        <!-- Stickers chile + lima -->
        <svg class="absolute top-4 right-4 w-16 h-16 sm:w-20 sm:h-20 rotate-12 drop-shadow-lg">
          <use href="#sticker-chile"/>
        </svg>

        <span class="sello text-amarillo">★ La estrella de la barra ★</span>
        <h3 class="mt-5 font-display text-4xl sm:text-6xl uppercase leading-[0.92]">Michelada</h3>
        <p class="serif-italic text-amarillo text-2xl sm:text-3xl mt-1">de la casa</p>
        <p class="mt-4 serif-body text-crema/85 text-base sm:text-lg max-w-md leading-snug">
          Cerveza muy fría, lima exprimida, chamoy, salsas y escarcha de tajín.
          Servida en jarra grande. La hacemos como en México, sin atajos.
        </p>
        <div class="mt-6 flex items-end gap-4">
          <span class="font-display text-5xl sm:text-6xl text-chile">5 €</span>
          <span class="font-mono text-[10px] uppercase tracking-widest text-crema/60 pb-2">jarra grande</span>
        </div>
      </div>
    </article>

    <!-- BLOQUE 3: Cervezas con foto Modelo + Corona -->
    <article class="relative bg-crema rounded-3xl overflow-hidden shadow-2xl grid md:grid-cols-5 gap-0">
      <!-- 2 fotos cervezas en split -->
      <div class="md:col-span-2 grid grid-cols-2 gap-0">
        <div class="relative aspect-[3/4] overflow-hidden">
          <img src="/images/bebidas/cerveza-corona.jpg" alt="Corona Extra con lima" class="w-full h-full object-cover" loading="lazy"/>
        </div>
        <div class="relative aspect-[3/4] overflow-hidden">
          <img src="/images/bebidas/cerveza-modelo.jpg" alt="Modelo Especial" class="w-full h-full object-cover" loading="lazy"/>
        </div>
      </div>

      <!-- Contenido cervezas -->
      <div class="md:col-span-3 p-6 sm:p-8 flex flex-col justify-between">
        <div>
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-display text-3xl sm:text-4xl text-noche uppercase tracking-tight">Cerveza fría</h3>
            <span class="font-display text-2xl text-crema bg-chile px-3 py-1 rounded-full">3 €</span>
          </div>
          <p class="serif-body text-noche/80 text-base leading-snug mb-5">
            Cervezas mexicanas auténticas, servidas a la temperatura exacta.
            Pídela con limón si manda el alma.
          </p>
          <div class="flex flex-wrap gap-1.5">
            {cervezasSabores.map((s) => (
              <span class="px-2.5 py-1 text-[10px] font-mono uppercase tracking-widest bg-noche text-crema rounded-full">
                {s}
              </span>
            ))}
          </div>
        </div>
        <p class="mt-5 font-hand text-2xl text-jade">355 ml de México puro</p>
      </div>
    </article>

    <!-- Aguas frescas -->
    <p class="mt-12 text-center font-hand text-2xl sm:text-3xl text-noche">
      + aguas frescas de horchata, jamaica y tamarindo
      <span class="block text-base sm:text-lg text-noche/70 font-body mt-1 italic">
        recién hechas cada mañana
      </span>
    </p>
  </div>
</section>
