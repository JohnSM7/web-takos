---
// Stickers SVG estilo lotería/pegatina — usados como elementos decorativos flotantes
// Cada uno se puede posicionar con clases tailwind
---

<!-- Definiciones SVG reutilizables -->
<svg width="0" height="0" style="position:absolute" aria-hidden="true">
  <defs>
    <!-- Chile / jalapeño rojo -->
    <symbol id="sticker-chile" viewBox="0 0 100 100">
      <g>
        <path d="M50 18 Q44 22 46 28 Q42 24 38 26 Q40 32 46 32" fill="#2D9B6B" stroke="#0B0908" stroke-width="2.5" stroke-linejoin="round"/>
        <path d="M48 30 Q30 38 28 60 Q28 80 48 88 Q68 84 70 62 Q70 42 56 32 Z" fill="#DC2626" stroke="#0B0908" stroke-width="2.5" stroke-linejoin="round"/>
        <ellipse cx="40" cy="52" rx="4" ry="8" fill="#FAF6EC" opacity="0.4"/>
      </g>
    </symbol>

    <!-- Lima verde -->
    <symbol id="sticker-lima" viewBox="0 0 100 100">
      <g>
        <circle cx="50" cy="50" r="34" fill="#9CC23B" stroke="#0B0908" stroke-width="2.5"/>
        <circle cx="50" cy="50" r="26" fill="#FAF6EC" stroke="#9CC23B" stroke-width="2"/>
        <g stroke="#9CC23B" stroke-width="1.5" fill="none">
          <line x1="50" y1="26" x2="50" y2="74"/>
          <line x1="28" y1="50" x2="72" y2="50"/>
          <line x1="32" y1="32" x2="68" y2="68"/>
          <line x1="32" y1="68" x2="68" y2="32"/>
        </g>
        <circle cx="50" cy="50" r="3" fill="#9CC23B"/>
      </g>
    </symbol>

    <!-- Jarrito de tamarindo (botella tipo Jarritos) -->
    <symbol id="sticker-jarrito" viewBox="0 0 100 100">
      <g>
        <!-- tapa -->
        <rect x="38" y="14" width="24" height="8" rx="2" fill="#F2D785" stroke="#0B0908" stroke-width="2"/>
        <!-- cuello -->
        <rect x="42" y="22" width="16" height="10" fill="#E87A2C" stroke="#0B0908" stroke-width="2"/>
        <!-- cuerpo -->
        <path d="M38 32 Q34 38 34 50 L34 82 Q34 88 40 88 L60 88 Q66 88 66 82 L66 50 Q66 38 62 32 Z" fill="#DC2626" stroke="#0B0908" stroke-width="2.5"/>
        <!-- Etiqueta -->
        <rect x="38" y="48" width="24" height="22" fill="#F2D785" stroke="#0B0908" stroke-width="1.5"/>
        <text x="50" y="63" text-anchor="middle" font-family="Archivo Black, sans-serif" font-size="8" fill="#0B0908">JARRITO</text>
      </g>
    </symbol>

    <!-- Michelada en jarra -->
    <symbol id="sticker-michelada" viewBox="0 0 100 100">
      <g>
        <!-- Jarra -->
        <path d="M28 28 L28 82 Q28 88 34 88 L66 88 Q72 88 72 82 L72 28 Z" fill="#FAF6EC" stroke="#0B0908" stroke-width="2.5"/>
        <!-- Cerveza ambarina -->
        <path d="M30 40 L30 80 Q30 86 36 86 L64 86 Q70 86 70 80 L70 40 Z" fill="#E8A53A"/>
        <!-- Espuma -->
        <ellipse cx="50" cy="38" rx="22" ry="6" fill="#FAF6EC"/>
        <circle cx="38" cy="34" r="3" fill="#FAF6EC"/>
        <circle cx="56" cy="32" r="4" fill="#FAF6EC"/>
        <!-- Escarcha chile (tajín) -->
        <rect x="28" y="28" width="44" height="6" fill="#DC2626" opacity="0.55"/>
        <!-- Asa -->
        <path d="M72 42 Q82 42 82 60 Q82 78 72 78" fill="none" stroke="#0B0908" stroke-width="2.5"/>
        <!-- Lima -->
        <circle cx="78" cy="32" r="6" fill="#9CC23B" stroke="#0B0908" stroke-width="1.5"/>
      </g>
    </symbol>

    <!-- Calavera azúcar -->
    <symbol id="sticker-calavera" viewBox="0 0 100 100">
      <g>
        <ellipse cx="50" cy="44" rx="28" ry="32" fill="#FAF6EC" stroke="#0B0908" stroke-width="2.5"/>
        <rect x="38" y="72" width="24" height="12" fill="#FAF6EC" stroke="#0B0908" stroke-width="2.5"/>
        <!-- Ojos flor -->
        <circle cx="38" cy="42" r="6" fill="#DC2626"/>
        <circle cx="38" cy="42" r="3" fill="#0B0908"/>
        <circle cx="62" cy="42" r="6" fill="#2D9B6B"/>
        <circle cx="62" cy="42" r="3" fill="#0B0908"/>
        <!-- Pétalos rojo -->
        <g fill="#DC2626"><circle cx="32" cy="36" r="2"/><circle cx="44" cy="36" r="2"/><circle cx="32" cy="48" r="2"/><circle cx="44" cy="48" r="2"/></g>
        <g fill="#2D9B6B"><circle cx="56" cy="36" r="2"/><circle cx="68" cy="36" r="2"/><circle cx="56" cy="48" r="2"/><circle cx="68" cy="48" r="2"/></g>
        <!-- Nariz corazón -->
        <path d="M50 52 L46 58 L50 64 L54 58 Z" fill="#0B0908"/>
        <!-- Boca dientes -->
        <path d="M40 70 L60 70" stroke="#0B0908" stroke-width="2"/>
        <g stroke="#0B0908" stroke-width="1.5">
          <line x1="44" y1="70" x2="44" y2="74"/>
          <line x1="48" y1="70" x2="48" y2="74"/>
          <line x1="52" y1="70" x2="52" y2="74"/>
          <line x1="56" y1="70" x2="56" y2="74"/>
        </g>
      </g>
    </symbol>

    <!-- Cactus -->
    <symbol id="sticker-cactus" viewBox="0 0 100 100">
      <g>
        <!-- maceta -->
        <rect x="34" y="74" width="32" height="14" fill="#E87A2C" stroke="#0B0908" stroke-width="2"/>
        <!-- tronco principal -->
        <rect x="42" y="30" width="16" height="46" rx="8" fill="#2D9B6B" stroke="#0B0908" stroke-width="2.5"/>
        <!-- brazos -->
        <path d="M42 50 L34 50 L34 38" stroke="#2D9B6B" stroke-width="10" fill="none" stroke-linecap="round"/>
        <path d="M42 50 L34 50 L34 38" stroke="#0B0908" stroke-width="2" fill="none" stroke-linecap="round"/>
        <path d="M58 56 L66 56 L66 44" stroke="#2D9B6B" stroke-width="10" fill="none" stroke-linecap="round"/>
        <path d="M58 56 L66 56 L66 44" stroke="#0B0908" stroke-width="2" fill="none" stroke-linecap="round"/>
        <!-- espinas -->
        <g stroke="#0B0908" stroke-width="1.2">
          <line x1="46" y1="40" x2="46" y2="36"/>
          <line x1="50" y1="48" x2="50" y2="44"/>
          <line x1="54" y1="56" x2="54" y2="52"/>
          <line x1="46" y1="62" x2="46" y2="58"/>
          <line x1="50" y1="70" x2="50" y2="66"/>
        </g>
        <!-- flor -->
        <circle cx="50" cy="28" r="4" fill="#DC2626" stroke="#0B0908" stroke-width="1.5"/>
      </g>
    </symbol>
  </defs>
</svg>
